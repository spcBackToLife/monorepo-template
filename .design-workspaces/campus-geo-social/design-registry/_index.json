  "globalState": {
    "ref": "product-analysis/PRD.md#四数据架构概要",
    "variables": [
      {
        "key": "currentUser",
        "type": "User",
        "purpose": "全局用户身份"
      },
      {
        "key": "primaryCampusId",
        "type": "bigint",
        "purpose": "主校园 ID（决定 M1 默认归属/M4 主校园）"
      },
      {
        "key": "viewingCampusId",
        "type": "bigint",
        "purpose": "当前漫游中的校园 ID（=primary 或外校）"
      },
      {
        "key": "isInRoamingMode",
        "type": "bool",
        "purpose": "是否在跨校漫游模式（影响互动按钮置灰）"
      },
      {
        "key": "wallet",
        "type": "{ coin: int, gem: int }",
        "purpose": "钱包余额，常驻顶层（影响所有付费交互）"
      },
      {
        "key": "deviceLocation",
        "type": "{ lat, lng, accuracy }",
        "purpose": "当前 GPS（用于触发判定，不上报历史）"
      },
      {
        "key": "verificationStatus",
        "type": "enum",
        "purpose": "认证状态：影响功能权限"
      },
      {
        "key": "privacyMode",
        "type": "bool",
        "purpose": "全局隐私模式开关"
      },
      {
        "key": "unreadCounts",
        "type": "{ messages, greets, notifications, friendRequests }",
        "purpose": "Tab 红点数据"
      }
    ]
  },

        "ref": "interaction-design/pages/00-auth-status.md#操作清单:5"
      },
      "boundary": {
        "summary": "已申诉一次→按钮置灰",
        "ref": "interaction-design/pages/00-auth-status.md#边界情况"
      }
    },
    "states": [
      "hidden",
      "visible",
      "disabled",
      "pressing"
    ]
  },
  "implementation": {
    "nodeId": null,
    "status": "pending"
  }
}

{
  "id": "submit-btn",
  "type": "element",
  "name": "保存按钮",
  "interaction": {
    "summary": "click→提交修改请求",
    "ref": "interaction-design/pages/11-change-password.md#操作清单:6",
    "trigger": "click",
    "condition": "{{ formValid }}",
    "flows": {
      "success": {
        "summary": "Toast「修改成功，其他设备已下线」+ 1.5s pop",
        "ref": "interaction-design/pages/11-change-password.md#状态机"
      },
      "error": {
        "summary": "按业务码：wrong-old/locked/weak/same-as-old",
        "ref": "interaction-design/pages/11-change-password.md#错误处理"
      },
      "boundary": {
        "summary": "800ms 防抖",
        "ref": "interaction-design/pages/11-change-password.md#操作清单:6"
      }
    },
    "states": [
      "disabled",
      "enabled",
      "submitting",
      "success",
      "error"
    ]
  },
  "implementation": {
    "nodeId": null,
    "status": "pending"
  }
}

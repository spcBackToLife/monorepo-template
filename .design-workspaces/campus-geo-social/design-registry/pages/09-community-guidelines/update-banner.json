{
  "id": "update-banner",
  "type": "element",
  "name": "新版本变更提示 Banner",
  "interaction": {
    "summary": "click→滚到\"变更摘要\"章节；仅 acceptedVersion < currentVersion 时显示",
    "ref": "interaction-design/pages/09-community-guidelines.md#操作清单:7",
    "trigger": "click",
    "condition": "{{ acceptedVersion < currentVersion && source != \"register\" }}",
    "flows": {
      "success": {
        "summary": "平滑滚到变更摘要章节",
        "ref": "interaction-design/pages/09-community-guidelines.md#操作清单:7"
      },
      "boundary": {
        "summary": "注册场景下隐藏",
        "ref": "interaction-design/pages/09-community-guidelines.md#边界情况"
      }
    },
    "states": [
      "hidden",
      "visible",
      "pressing"
    ]
  },
  "implementation": {
    "nodeId": null,
    "status": "pending"
  }
}

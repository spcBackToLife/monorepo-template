{
  "id": "password-input",
  "type": "element",
  "name": "密码输入框（含眼睛切换）",
  "interaction": {
    "summary": "input→隐藏字符；眼睛 click→toggle 明/暗",
    "ref": "interaction-design/pages/00-login.md#操作清单:5",
    "trigger": "input",
    "condition": "{{ mode == \"password-mode\" }}",
    "flows": {
      "success": {
        "summary": "长度满足激活 submit",
        "ref": "interaction-design/pages/00-login.md#操作清单:5"
      },
      "error": {
        "summary": "密码错 ≥5 次 → error:locked Modal",
        "ref": "interaction-design/pages/00-login.md#错误处理"
      }
    },
    "states": [
      "empty",
      "inputting",
      "masked",
      "unmasked",
      "error",
      "disabled"
    ]
  },
  "content": {
    "type": "text",
    "value": "密码"
  },
  "materials": [
    {
      "id": "I-01",
      "summary": "睁眼图标（密码明文时显示）",
      "ref": "design-plan/pages/00-login/materials/I-01-eye-open.md",
      "condition": "{{state.view.passwordVisible === true}}"
    },
    {
      "id": "I-02",
      "summary": "闭眼图标（密码密文时显示，默认）",
      "ref": "design-plan/pages/00-login/materials/I-02-eye-closed.md",
      "condition": "{{state.view.passwordVisible !== true}}"
    }
  ],
  "_updatedAt": "2026-05-29T08:27:37.097Z",
  "design": {
    "summary": "密码输入框 h:48 radius:md，右侧内联 eye-toggle(I-01/I-02) 44×44触摸区",
    "keyStyles": {
      "height": "48px",
      "borderRadius": "12px",
      "border": "1px solid #FFE0E8",
      "paddingRight": "48px"
    },
    "visualStates": {
      "focus": {
        "border": "2px solid #FF6F91",
        "boxShadow": "0 0 0 3px rgba(255,111,145,0.1)"
      },
      "error": {
        "border": "2px solid #ED5A5A",
        "boxShadow": "0 0 0 3px rgba(237,90,90,0.1)"
      },
      "disabled": {
        "background": "rgba(45,36,56,0.03)",
        "border": "1px solid #F5EDE6",
        "color": "rgba(45,36,56,0.42)"
      }
    }
  },
  "implementation": {
    "groupId": "nd_a971ea91ca694dbcb45d8",
    "fieldId": "nd_5eff2e17da2d46f295c18",
    "eyeToggleId": "nd_840dd7b8d45846cababd6",
    "eyeOpenIconId": "nd_d5b546035cd84324a1c27",
    "eyeClosedIconId": "nd_635f0406e1ba467fb3c4e",
    "status": "completed",
    "checklist": {
      "structure": true,
      "styles": true,
      "events": true,
      "materials": false,
      "visualStates": true
    },
    "notes": "password input bind view.password, type 用条件表达式; 眼睛 toggle state.view.passwordVisible; eye-open/closed 图标各自 visibleWhen 在 EyeToggle 内，等待 I-01/I-02 素材 export_and_apply。"
  }
}

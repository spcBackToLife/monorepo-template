{
  "id": "submit-btn",
  "type": "element",
  "name": "登录按钮",
  "interaction": {
    "summary": "click→提交登录请求；处理 11 种状态",
    "ref": "interaction-design/pages/00-login.md#操作清单:6",
    "trigger": "click",
    "condition": "{{ formValid && state != \"submitting\" }}",
    "flows": {
      "success": {
        "summary": "✓ 触觉 + 0.5s 跳目标页（home / auth-status）",
        "ref": "interaction-design/pages/00-login.md#状态机"
      },
      "error": {
        "summary": "按错误类型路由：credential/locked/banned/logging-off/remote-login",
        "ref": "interaction-design/pages/00-login.md#错误处理"
      },
      "timeout": {
        "summary": "15s 超时恢复 + Toast「网络异常」",
        "ref": "interaction-design/pages/00-login.md#错误处理"
      },
      "boundary": {
        "summary": "800ms 防抖防重复",
        "ref": "interaction-design/pages/00-login.md#操作清单:6"
      }
    },
    "states": [
      "disabled",
      "enabled",
      "submitting",
      "success",
      "error"
    ]
  },
  "content": {
    "type": "text",
    "value": "登录"
  },
  "materials": [
    {
      "id": "I-04",
      "summary": "成功 checkmark 图标（success 态显示）",
      "ref": "design-plan/pages/00-login/materials/I-04-checkmark-success.md",
      "condition": "{{state.view.submitState === \"success\"}}"
    }
  ],
  "_updatedAt": "2026-05-29T08:32:23.790Z",
  "design": {
    "summary": "登录主按钮 h:48 w:100% bg:primary color:white radius:full shadow-sm，5态(disabled/enabled/hover/pressed/loading/success)",
    "visualRef": "design-plan/pages/00-login/visual.md#登录按钮",
    "keyStyles": {
      "height": "48px",
      "width": "100%",
      "background": "#FF6F91",
      "color": "#FFFFFF",
      "borderRadius": "9999px",
      "fontSize": "16px",
      "fontWeight": "600",
      "boxShadow": "token:shadow-sm",
      "marginTop": "24px"
    },
    "visualStates": {
      "hover": {
        "background": "#FF89A4",
        "transform": "scale(1.03)"
      },
      "pressed": {
        "background": "#FB406F",
        "transform": "scale(0.97)",
        "boxShadow": "none"
      },
      "disabled": {
        "opacity": "0.45"
      },
      "loading": {
        "content": "spinner"
      },
      "success": {
        "background": "#3FCC93",
        "content": "I-04 checkmark"
      }
    }
  },
  "implementation": {
    "nodeId": "nd_de8ceefe05ca4904bcf94",
    "status": "completed",
    "checklist": {
      "structure": true,
      "styles": true,
      "events": true,
      "materials": false,
      "visualStates": true
    },
    "notes": "主按钮已建+5态(hover/pressed/disabled/submitting/success)。click 事件含校验 condition + state.submitState 状态机；I-04 checkmark 在素材 task#37 时通过条件应用注入到 success visualState 的 backgroundImage。"
  }
}

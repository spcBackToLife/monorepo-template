{
  "id": "confirm-btn",
  "type": "element",
  "name": "确认",
  "interaction": {
    "summary": "click→pop 回 edit（带 location）",
    "ref": "interaction-design/pages/01-publish-pick-location.md#操作清单:7",
    "trigger": "click",
    "condition": "{{ pinSettled && radiusSelected }}",
    "flows": {
      "success": {
        "summary": "主校园内→pop；校外→out-of-campus-warn",
        "ref": "interaction-design/pages/01-publish-pick-location.md#状态机"
      },
      "error": {
        "summary": "边界查询失败→Toast",
        "ref": "interaction-design/pages/01-publish-pick-location.md#错误处理"
      },
      "boundary": {
        "summary": "800ms 防抖",
        "ref": "interaction-design/pages/01-publish-pick-location.md#操作清单:7"
      }
    },
    "states": [
      "disabled",
      "enabled",
      "submitting"
    ]
  },
  "implementation": {
    "nodeId": null,
    "status": "pending"
  }
}

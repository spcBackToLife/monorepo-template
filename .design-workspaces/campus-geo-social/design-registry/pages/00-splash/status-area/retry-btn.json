{
  "id": "retry-btn",
  "type": "element",
  "name": "重试按钮",
  "interaction": {
    "summary": "click→重新启动 token/version 检查",
    "ref": "interaction-design/pages/00-splash.md#操作清单:2",
    "trigger": "click",
    "condition": "{{ pageState == \"timeout\" }}",
    "flows": {
      "success": {
        "summary": "重置为 bootstrapping，再次并行检查",
        "ref": "interaction-design/pages/00-splash.md#状态机:transitions"
      },
      "error": {
        "summary": "二次失败→提示\"打开网络设置\"",
        "ref": "interaction-design/pages/00-splash.md#操作清单:2"
      }
    },
    "states": [
      "hidden",
      "visible",
      "pressing",
      "disabled"
    ]
  },
  "implementation": {
    "nodeId": null,
    "status": "pending"
  }
}

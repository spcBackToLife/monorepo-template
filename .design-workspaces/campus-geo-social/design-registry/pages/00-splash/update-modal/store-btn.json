{
  "id": "store-btn",
  "type": "element",
  "name": "去应用商店按钮",
  "interaction": {
    "summary": "click→跳出 App 到应用商店",
    "ref": "interaction-design/pages/00-splash.md#操作清单:3",
    "trigger": "click",
    "condition": "{{ pageState == \"updating-blocked\" }}",
    "flows": {
      "success": {
        "summary": "触觉 medium + 跳出 App",
        "ref": "interaction-design/pages/00-splash.md#操作清单:3"
      },
      "error": {
        "summary": "Toast「应用商店未安装」",
        "ref": "interaction-design/pages/00-splash.md#错误处理"
      }
    },
    "states": [
      "idle",
      "pressing"
    ]
  },
  "implementation": {
    "nodeId": null,
    "status": "pending"
  }
}

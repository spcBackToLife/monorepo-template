{
  "id": "send-code-btn",
  "type": "element",
  "name": "获取验证码",
  "interaction": {
    "summary": "click→发送+60s 倒计时",
    "ref": "interaction-design/pages/00-forgot-password.md#操作清单:2",
    "trigger": "click",
    "condition": "{{ phoneValid }}",
    "flows": {
      "success": {
        "summary": "Toast「已发送」",
        "ref": "interaction-design/pages/00-forgot-password.md#操作清单:2"
      },
      "error": {
        "summary": "通道异常→语音备选",
        "ref": "interaction-design/pages/00-forgot-password.md#错误处理"
      }
    },
    "states": [
      "disabled",
      "enabled",
      "countdown"
    ]
  },
  "implementation": {
    "nodeId": null,
    "status": "pending"
  }
}

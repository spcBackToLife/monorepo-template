{
  "id": "save-btn",
  "type": "element",
  "name": "保存",
  "interaction": {
    "summary": "click→pop 回 edit",
    "ref": "interaction-design/pages/01-publish-visibility.md#操作清单:12",
    "trigger": "click",
    "condition": "{{ visibility != \"friends\" || selectedFriends.length >= 1 }}",
    "flows": {
      "success": {
        "summary": "saving→pop 回 edit",
        "ref": "interaction-design/pages/01-publish-visibility.md#状态机"
      },
      "error": {
        "summary": "friends 未选→inline",
        "ref": "interaction-design/pages/01-publish-visibility.md#错误处理"
      }
    },
    "states": [
      "disabled",
      "enabled",
      "saving"
    ]
  },
  "implementation": {
    "nodeId": null,
    "status": "pending"
  }
}

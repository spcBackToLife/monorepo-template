{
  "id": "send-code-btn",
  "type": "element",
  "name": "获取验证码按钮",
  "interaction": {
    "summary": "click→发送+60s 倒计时",
    "ref": "interaction-design/pages/00-register.md#操作清单:2",
    "trigger": "click",
    "condition": "{{ phoneValid && state != \"code-sending\" }}",
    "flows": {
      "success": {
        "summary": "Toast「已发送」+ 倒计时",
        "ref": "interaction-design/pages/00-register.md#操作清单:2"
      },
      "error": {
        "summary": "通道异常→Sheet 语音验证码备选",
        "ref": "interaction-design/pages/00-register.md#错误处理"
      }
    },
    "states": [
      "disabled",
      "enabled",
      "sending",
      "countdown"
    ]
  },
  "implementation": {
    "nodeId": null,
    "status": "pending"
  }
}
